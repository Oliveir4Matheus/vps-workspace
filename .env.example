# --- obrigatorias ---

# Token do bot Telegram — crie via @BotFather
TELEGRAM_TOKEN=

# IDs de usuario autorizados, separados por virgula — descubra no @userinfobot
ALLOWED_USER_IDS=

# Token OAuth do Claude Code — gere na VPS com: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# --- opcionais ---

# Repositorio clonado no primeiro start (se /workspace estiver vazio)
REPO_URL=

# Identidade git para commits
GIT_USER_NAME=
GIT_USER_EMAIL=

# Chave SSH privada para repos privados (alternativa: usar o comando 'setup')
SSH_PRIVATE_KEY=

# Diretorio de trabalho do Claude (padrao: /workspace)
WORK_DIR=/workspace

# Timeout por instrucao, em segundos (padrao: 300)
CLAUDE_TIMEOUT=300
