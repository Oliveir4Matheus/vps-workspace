# --- obrigatorias ---

# Token do bot Telegram — crie via @BotFather
TELEGRAM_TOKEN=

# IDs de usuario autorizados, separados por virgula — descubra no @userinfobot
ALLOWED_USER_IDS=

# Token OAuth do Claude Code — gere na VPS com: claude setup-token
CLAUDE_CODE_OAUTH_TOKEN=

# --- opcionais ---

# Repositorio clonado no primeiro start (se /workspace estiver vazio)
REPO_URL=

# Identidade git para commits
GIT_USER_NAME=
GIT_USER_EMAIL=

# Chave SSH privada para repos privados (alternativa: usar o comando 'setup')
SSH_PRIVATE_KEY=

# Token do GitHub (Personal Access Token) — autentica o gh e o git via HTTPS
# automaticamente no start. Alternativa: autenticar pelo comando 'setup'
GH_TOKEN=

# Diretorio de trabalho do Claude (padrao: /workspace)
WORK_DIR=/workspace

# Timeout por instrucao, em segundos (padrao: 300)
CLAUDE_TIMEOUT=300

# Modelo inicial do Claude (vazio = padrao do claude). Ajustavel via /model
CLAUDE_MODEL=

# Effort inicial: low | medium | high | max (padrao: high). Ajustavel via /effort
CLAUDE_EFFORT=high

# Iniciar o bot Telegram automaticamente no boot do container.
# Valores: true | false  (padrao: true). Pode parar/iniciar depois via 'setup'
ENABLE_BOT=true

# Iniciar uma sessao interativa do Claude com --remote-control assim que o
# container subir (controlavel via claude.ai). Roda em tmux detached.
# Valores: true | false  (padrao: false)
CLAUDE_REMOTE_CONTROL=false

# Nome da sessao remote-control (aparece no claude.ai). Opcional.
CLAUDE_REMOTE_CONTROL_NAME=
